<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="FreeRide"
        android:supportsRtl="true"
        android:theme="@style/Theme.FreeRide">

        <meta-data android:name="app.category.primary" android:value="fitness" />

        <!-- VeloLauncher workout app discovery -->
        <meta-data android:name="io.freewheel.workout_app" android:value="true" />
        <meta-data android:name="io.freewheel.workout_description"
                   android:value="Free ride with real-time power, cadence, and heart rate" />

        <activity
            android:name=".RideActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustPan">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Launched by VeloLauncher with workout data -->
            <intent-filter>
                <action android:name="io.freewheel.freeride.ACTION_START_RIDE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".RideSummaryActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.FreeRide" />

        <service
            android:name=".OverlayService"
            android:exported="false" />
    </application>
</manifest>
